# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cafeteria
POSTGRES_USER=cafeteria
POSTGRES_PASSWORD=cafeteria

# PgBouncer (for service-to-DB pooling)
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=5432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Cache
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# Services (internal docker DNS)
IDENTITY_PROVIDER_URL=http://identity-provider:8000
ORDER_GATEWAY_URL=http://order-gateway:8000
STOCK_SERVICE_URL=http://stock-service:8000
KITCHEN_QUEUE_URL=http://kitchen-queue:8000
NOTIFICATION_HUB_URL=http://notification-hub:8000
PAYMENT_SERVICE_URL=http://payment-service:8000

# Auth / JWT
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
ADMIN_STUDENT_IDS=admin-demo

# Gateway tuning
STOCK_CACHE_TTL_SECONDS=3

# Gateway cookie/CORS auth
CORS_ALLOWED_ORIGINS=http://localhost:3000
ACCESS_COOKIE_NAME=access_token
COOKIE_SECURE=false

# Web frontend runtime
NEXT_PUBLIC_API_MODE=real
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002
NEXT_PUBLIC_API_PREFIX=/api
NEXT_PUBLIC_NOTIFICATION_WS_URL=ws://localhost:8005/ws

# Mobile frontend runtime
EXPO_PUBLIC_API_MODE=real
EXPO_PUBLIC_API_BASE_URL=http://localhost:8002
EXPO_PUBLIC_API_PREFIX=/api
EXPO_PUBLIC_NOTIFICATION_WS_URL=ws://localhost:8005/ws

# Admin dashboard health checks (server-side route in web app)
# Example:
# ADMIN_HEALTH_CHECKS_JSON=[{"name":"order-gateway","url":"https://api.example.com/health"},{"name":"notification-hub","url":"https://notify.example.com/health"}]
ADMIN_HEALTH_GATEWAY_URL=http://localhost:8002
